# 複製此檔案為 .env.local 並填入實際值

# --- Meta / Facebook ---
# 取得方式：https://developers.facebook.com/ → 你的 App → 基本設定
FACEBOOK_APP_ID=3975265669431231
FACEBOOK_APP_SECRET=1eede6e30c840f2bbd7c36af5c199084

# --- NextAuth ---
# 生成方式：openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# 正式環境（Vercel 部署後改為實際網址）
# NEXTAUTH_URL=https://fb-auto-post.vercel.app

# --- Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- OpenAI DALL-E 3 ---
OPENAI_API_KEY=sk-xxxx
